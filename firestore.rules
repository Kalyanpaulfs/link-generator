rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // Helper Functions
    // -------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return userExists() &&
             userDoc().data.role == 'super_admin';
    }

    function isAdmin() {
      return userExists() &&
             (userDoc().data.role == 'admin' ||
              userDoc().data.role == 'super_admin');
    }

    // Safe subscription check (won’t break old data)
    function isSubscribed() {
      return userExists() &&
        (
          userDoc().data.role in ['admin', 'super_admin'] ||

          (
            userDoc().data.subscriptionStatus in ['active', 'trial'] &&
            userDoc().data.subscriptionExpiry is int &&
            userDoc().data.subscriptionExpiry > request.time.toMillis()
          )
        );
    }

    function isValidLinkCreate() {
      let data = request.resource.data;

      return (
        data.slug is string &&
        data.slug.size() >= 4 &&
        data.slug.size() <= 30 &&
        data.whatsappNumber is string &&
        data.userId == request.auth.uid &&
        data.active is bool &&
        (data.clicks == 0 || data.clicks == null)
      );
    }

    function isValidLinkUpdate() {
      let newData = request.resource.data;
      let oldData = resource.data;

      return (
        newData.userId == request.auth.uid &&
        newData.slug == oldData.slug &&           // Slug cannot change
        newData.clicks == oldData.clicks &&       // Clicks cannot change
        newData.whatsappNumber is string          // Number can change
      );
    }

    // -------------------------
    // Collections
    // -------------------------

    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());

      allow create: if isAuthenticated() && request.auth.uid == uid;

      allow update: if isSuperAdmin() ||
                    (isAdmin() && resource.data.role != 'super_admin');

      allow delete: if isSuperAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow write: if isAdmin();
    }

    match /payments/{payId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /links/{linkId} {

      // SAFE READ (no disappearing data)
      allow read: if
        (isAuthenticated() && resource.data.userId == request.auth.uid)
        || isAdmin();

      // Admin full control
      allow write: if isAdmin();

      // User create
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid &&
                    isSubscribed() &&
                    isValidLinkCreate();

      // User update (trial + active allowed)
      allow update: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid &&
                    isSubscribed() &&
                    isValidLinkUpdate();

      // User delete own link
      allow delete: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;
    }

    match /otps/{email} {
      allow read, write: if false;
    }
  }
}