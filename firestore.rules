rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Check if the REQUESTER is a super_admin
    function isSuperAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Check if the REQUESTER is an admin (includes super_admin)
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }

    function isValidLink() {
      let data = request.resource.data;
      return (
        data.slug is string &&
        data.whatsappNumber is string &&
        data.userId == request.auth.uid && 
        data.slug.size() >= 4 && 
        data.slug.size() <= 30 &&
        data.active is bool &&
        (data.clicks == 0 || data.clicks == null) // Initial clicks must be 0
      );
    }

    // Separate validation for updates: allows existing clicks, prevents slug/clicks tampering
    function isValidLinkUpdate() {
      let data = request.resource.data;
      return (
        data.whatsappNumber is string &&
        data.userId == request.auth.uid &&
        data.slug == resource.data.slug &&          // Slug cannot be changed
        data.clicks == resource.data.clicks          // Clicks cannot be tampered with
      );
    }

    match /otps/{email} {
      // Auth OTPs are handled exclusively via Admin SDK (server actions)
      allow read, write: if false;
    }

    // --- Collection Rules ---

    function isSubscribed() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.role == 'admin' || user.role == 'super_admin' || 
             ((user.subscriptionStatus == 'active' || user.subscriptionStatus == 'trial') && 
              (user.subscriptionExpiry > request.time.toMillis()));
    }

    match /users/{uid} {
      // Owner can read their own, Admin/SuperAdmin can read all
      allow read: if isOwner(uid) || isAdmin();
      
      // Only Super Admin can change roles or delete users
      // Regular Admins can update other user data (like subscriptionStatus)
      allow write: if isSuperAdmin() || (isAdmin() && !('role' in request.resource.data));
      
      // Prevent ANYONE from demoting a Super Admin via client SDK
      allow update: if (isSuperAdmin() || isAdmin()) && 
                     (resource.data.role != 'super_admin' || request.resource.data.role == 'super_admin');

      // Note: First super_admin must be set via Firebase Console.
    }

    match /subscriptions/{subId} {
        allow get: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
        allow list: if isAdmin();
        // Admin creates/updates subscriptions
        allow write: if isAdmin();
    }

    match /payments/{payId} {
        allow get: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
        allow list: if isAdmin();
        // User creates payments
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        // Admin updates status
        allow update: if isAdmin();
    }

    match /settings/{docId} {
        allow read: if isAuthenticated();
        // Admin can write settings
        allow write: if isAdmin();
    }

    match /links/{linkId} {
      // Owner can read/write, Admin can read/list
      allow get: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if (isAuthenticated() && query.limit <= 100) || isAdmin(); // Standard limit or admin
      
      // Admin can also delete/update specific links if needed (moderation)
      allow write: if isAdmin();

      // Standard user logic
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    isSubscribed() &&
                    isValidLink();

      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.userId == request.auth.uid &&
                    isSubscribed() &&
                    isValidLinkUpdate();

      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
